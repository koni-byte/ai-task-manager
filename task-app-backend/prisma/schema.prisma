// task-app-backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // ← この行を追加（またはコメントアウトを解除）します
}

// ユーザーテーブル
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  tasks     Task[]   // UserとTaskの1対多のリレーション
  messages  Message[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// タスクテーブル
model Task {
  id              String   @id @default(uuid())
  title           String
  description     String?  // ?は必須ではない（null許容）の意味
  priority        String   @default("medium") // high, medium, low
  deadline        DateTime?
  isAiGenerated   Boolean  @default(false) 
  completed     Boolean   @default(false)
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// AIチャット履歴テーブル
model Message {
  id        String   @id @default(uuid())
  content   String
  role      String   // "user" or "assistant"
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}